# Supabase is the primary cloud database and login provider.
# Find these in your Supabase project settings after you create a project.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-public-anon-key

# PowerSync provides the offline-first local SQLite sync layer.
# Add these after you create a PowerSync instance.
NEXT_PUBLIC_POWERSYNC_URL=https://your-powersync-instance.example.com

# Optional local demo mode. Keep this true until Supabase and PowerSync are connected.
NEXT_PUBLIC_USE_LOCAL_MOCKS=true
